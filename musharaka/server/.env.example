PORT=3001
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
REDIS_URL=redis://localhost:6379
ENCRYPTION_KEY=your-64-char-hex-key
CLIENT_ORIGIN=http://localhost:5173
SEINOMY_BASE_URL=https://api.seinomy.com
SEINOMY_MOCK=true
SEINOMY_TIMEOUT=10000

# Public Contracts API — set a strong random key for machine-to-machine access
# Leave empty to require standard JWT auth only
CONTRACTS_API_KEY=

# Bot integrations (Telegram + WhatsApp/Twilio)
# Required when running webhook endpoints — leave empty to disable bot auth in dev
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TWILIO_AUTH_TOKEN=

# Internal deploy-time process kill key (generated random string)
# Must match INTERNAL_KILL_KEY in the VPS server/.env for /api/internal/shutdown to work
INTERNAL_KILL_KEY=
